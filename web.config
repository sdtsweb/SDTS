<?xml version="1.0" encoding="UTF-8"?>
<!--
  Forces browsers to revalidate every request instead of silently reusing a
  cached copy. Without this, IIS sends Last-Modified/ETag but no
  Cache-Control header, so browsers fall back to heuristic caching and can
  keep showing a stale page (e.g. an old team roster) until a hard refresh.
-->
<configuration>
  <system.webServer>
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
  </system.webServer>
</configuration>
